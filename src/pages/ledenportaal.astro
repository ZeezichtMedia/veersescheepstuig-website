---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeader from "../components/SectionHeader.astro";

const heroImage = "/images/Ledenportaal_header.jpg";
const heroTitle = "Ledenportaal";
const heroSubtitle = "Informatie, kleding en oefenmateriaal voor leden";

const tenues = [
    {
        naam: "Zomertenue",
        icon: "☀️",
        items: [
            "Gestreepte polo",
            "Effen blauwe kiel",
            "Beige broek",
            "Donkerblauwe sokken",
            "Zwarte schoenen",
        ],
    },
    {
        naam: "Wintertenue",
        icon: "❄️",
        items: [
            "T-shirt (wit) met ronde hals",
            "Gestreepte kiel",
            "Donkerblauwe broek",
            "Donkerblauwe sokken",
            "Zwarte schoenen",
        ],
    },
    {
        naam: "Concerttenue",
        icon: "🎵",
        items: [
            "Wit onderhemd (zonder mouw)",
            "Wit overhemd met dasje (onder de kraag en knoopjes dicht)",
            "Gestreept hesje",
            "Donkerblauwe broek met bretels",
            "Donkerblauwe sokken",
            "Zwarte schoenen",
            "Zwarte riem",
        ],
    },
    {
        naam: "Tropentenue",
        icon: "🌴",
        items: [
            "Wit onderhemd (zonder mouw)",
            "Wit shirt met korte mouw en veter",
            "Blauwe broek",
            "Donkerblauwe sokken",
            "Zwarte schoenen",
        ],
    },
    {
        naam: "Begrafenis",
        icon: "🕊️",
        items: ["Wintertenue", "Rouwband (wordt uitgedeeld)", "Jack van HVS"],
    },
];
---

<BaseLayout
    title="Ledenportaal - Het Veerse Scheepstuig"
    description="Ledenportaal met kleding, oefenbestanden en bladmuziek voor de leden van Het Veerse Scheepstuig."
>
    <!-- Prevent indexing of member portal -->
    <meta name="robots" content="noindex, nofollow" slot="head" />

    <!-- Hero Section -->
    <section
        class="relative h-[60vh] flex items-center justify-center overflow-hidden"
    >
        <img
            src={heroImage}
            alt="Hero afbeelding Ledenportaal"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"
        >
        </div>

        <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
            <h1
                class="text-5xl md:text-7xl font-bold text-white mb-6 drop-shadow-2xl"
            >
                {heroTitle}
            </h1>
            <p class="text-xl md:text-2xl text-white/95 drop-shadow-lg">
                {heroSubtitle}
            </p>
        </div>
    </section>

    <!-- Tenues Foto Section -->
    <Section id="tenues-foto" padding="large">
        <div class="max-w-4xl mx-auto">
            <SectionHeader title="Onze Tenues" align="center" />
            <p class="text-center text-gray-600 mb-8 text-lg">
                Van links naar rechts: Tropentenue, Zomertenue, Wintertenue en
                Concerttenue
            </p>
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
                <img
                    src="/images/tenues_overzicht.jpg"
                    alt="Overzicht van de vier tenues: tropentenue, zomertenue, wintertenue en concerttenue"
                    class="w-full object-cover"
                    loading="lazy"
                />
                <!-- Labels onder de foto -->
                <div
                    class="absolute bottom-0 left-0 right-0 grid grid-cols-4 bg-gradient-to-t from-black/80 to-transparent"
                >
                    <div class="text-center text-white py-3 px-1">
                        <span class="text-2xl block">🌴</span>
                        <span class="text-sm font-semibold">Tropentenue</span>
                    </div>
                    <div class="text-center text-white py-3 px-1">
                        <span class="text-2xl block">☀️</span>
                        <span class="text-sm font-semibold">Zomertenue</span>
                    </div>
                    <div class="text-center text-white py-3 px-1">
                        <span class="text-2xl block">❄️</span>
                        <span class="text-sm font-semibold">Wintertenue</span>
                    </div>
                    <div class="text-center text-white py-3 px-1">
                        <span class="text-2xl block">🎵</span>
                        <span class="text-sm font-semibold">Concerttenue</span>
                    </div>
                </div>
            </div>
        </div>
    </Section>

    <!-- Kledinglijst Section -->
    <Section id="kledinglijst" padding="large">
        <div class="max-w-6xl mx-auto">
            <SectionHeader title="Kledinglijst per tenue" align="center" />

            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8"
            >
                {
                    tenues.map((tenue) => (
                        <div class="bg-white rounded-2xl shadow-xl p-6 md:p-8 hover:shadow-2xl transition-shadow duration-300 border border-gray-100">
                            <div class="flex items-center gap-3 mb-5">
                                <span class="text-3xl">{tenue.icon}</span>
                                <h3 class="text-xl font-bold text-primary">
                                    {tenue.naam}
                                </h3>
                            </div>
                            <ul class="space-y-2">
                                {tenue.items.map((item) => (
                                    <li class="flex items-start gap-2 text-gray-700">
                                        <span class="text-primary mt-1 text-sm">
                                            ▸
                                        </span>
                                        <span>{item}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </div>
    </Section>

    <!-- Uitleg Microfoon Section -->
    <Section id="uitleg-microfoon" padding="large">
        <div class="max-w-4xl mx-auto">
            <SectionHeader title="Uitleg Microfoon Gebruik" align="center" />
            <p class="text-center text-gray-600 mb-8 text-lg">
                Bekijk in deze video hoe je op de juiste manier gebruik maakt
                van de microfoons tijdens optredens.
            </p>
            <div
                class="relative w-full overflow-hidden rounded-2xl shadow-xl bg-gray-900"
                style="padding-top: 56.25%;"
            >
                <iframe
                    class="absolute top-0 left-0 w-full h-full border-0"
                    src="https://www.youtube-nocookie.com/embed/sN84I0baowg?rel=0"
                    title="Uitleg microfoon gebruik Veerse Scheepstuig"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                >
                </iframe>
            </div>
        </div>
    </Section>

    <!-- Muziekfiles / Finale section -->
    <Section id="muziekfiles" padding="large">
        <div class="max-w-4xl mx-auto">
            <SectionHeader title="Muziekfiles (Finale)" align="center" />

            <div
                class="prose prose-lg prose-primary max-w-none text-gray-700 bg-white p-8 md:p-12 rounded-2xl shadow-xl mt-8"
            >
                <p>
                    Binnenkort vindt u hier alle muziekfiles, oefenbestanden en
                    bladmuziek (o.a. Finale-bestanden) om thuis te kunnen
                    oefenen.
                </p>
                <p>
                    <em
                        >(Deze pagina wordt later nog verder aangevuld met
                        specifieke partijen)</em
                    >
                </p>
            </div>
        </div>
    </Section>
</BaseLayout>
