---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { sanityClient } from "../sanity/client";

export interface SanityNewsletter {
    _id: string;
    title: string;
    date: string;
    fileUrl: string;
}

// Fetch all newsletters from Sanity and sort by date
const newsletters: SanityNewsletter[] = await sanityClient.fetch(`
  *[_type == "newsletter"] | order(date desc) {
    _id,
    title,
    date,
    "fileUrl": file.asset->url
  }
`);

// Map to match the template structure
const sortedNewsletters = newsletters.map((newsletter) => ({
    ...newsletter,
    data: {
        title: newsletter.title,
        date: new Date(newsletter.date),
        fileUrl: newsletter.fileUrl,
    },
}));

// Format date for display
function formatDate(date: Date) {
    const months = [
        "januari",
        "februari",
        "maart",
        "april",
        "mei",
        "juni",
        "juli",
        "augustus",
        "september",
        "oktober",
        "november",
        "december",
    ];
    const month = months[date.getMonth()];
    const year = date.getFullYear();
    return `${month} ${year}`;
}
---

<BaseLayout
    title="Nieuwsbrieven - Het Veerse Scheepstuig"
    description="Lees onze laatste nieuwsbrieven en blijf op de hoogte van alle ontwikkelingen binnen Het Veerse Scheepstuig."
>
    <!-- Hero Section -->
    <section
        class="relative h-[60vh] flex items-center justify-center overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-primary-700 to-secondary-900"
        >
        </div>
        <div class="absolute inset-0 bg-black/30"></div>

        <div class="relative z-10 text-center px-4 max-w-5xl mx-auto mt-20">
            <div
                class="inline-block mb-6 px-6 py-2 bg-white/10 backdrop-blur-sm rounded-full border border-white/20"
            >
                <span
                    class="text-white/90 text-sm md:text-base font-medium tracking-wide"
                    >📰 Blijf op de hoogte</span
                >
            </div>
            <h1
                class="text-5xl md:text-7xl font-bold text-white mb-6 drop-shadow-2xl"
            >
                Nieuwsbrieven
            </h1>
            <p
                class="text-xl md:text-2xl text-white/95 drop-shadow-lg max-w-2xl mx-auto"
            >
                Lees het laatste nieuws, verslagen en aankondigingen van ons
                koor
            </p>
        </div>
    </section>

    <!-- Newsletters List -->
    <Section id="content" padding="large">
        <div class="max-w-5xl mx-auto">
            <SectionHeader
                title="Laatste Nieuwsbrieven"
                subtitle="Bekijk en download onze nieuwsbrieven"
            />

            <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
                {
                    sortedNewsletters.map((newsletter) => {
                        const { title, date, fileUrl } = newsletter.data;

                        return (
                            <div
                                class="bg-white rounded-2xl shadow-md border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 flex flex-col"
                                style="box-shadow: 0 0 15px rgba(0, 0, 0, 0.08);"
                            >
                                <div class="p-8 flex-1 flex flex-col">
                                    <div class="flex items-center gap-2 text-primary font-semibold mb-4">
                                        <svg
                                            class="w-5 h-5 flex-shrink-0"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                            />
                                        </svg>
                                        <span class="text-lg uppercase tracking-wider">
                                            {formatDate(date)}
                                        </span>
                                    </div>

                                    <h3 class="text-2xl font-bold text-gray-900 mb-6 flex-1">
                                        {title}
                                    </h3>

                                    <div class="pt-4 border-t border-gray-100 mt-auto">
                                        <a
                                            href={fileUrl}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center gap-2 bg-primary-50 text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-xl transition-colors w-full justify-center group"
                                        >
                                            <svg
                                                class="w-5 h-5 transition-transform group-hover:-translate-y-1"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                                />
                                            </svg>
                                            Download PDF
                                        </a>
                                    </div>
                                </div>
                            </div>
                        );
                    })
                }
            </div>
        </div>
    </Section>

    <!-- CTA Section -->
    <Section padding="large">
        <div class="max-w-4xl mx-auto text-center">
            <div
                class="bg-gradient-to-br from-primary-50 to-white p-8 md:p-12 rounded-3xl border border-primary-100 shadow-xl"
            >
                <h3 class="text-3xl font-bold text-gray-900 mb-4">
                    Niets missen?
                </h3>
                <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
                    Kom gezellig langs op één van onze concerten of neem contact
                    op voor meer informatie over Het Veerse Scheepstuig.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a
                        href="/concerten"
                        class="bg-primary text-white hover:bg-primary-700 font-bold px-8 py-4 rounded-xl transition-all shadow-md hover:shadow-lg"
                    >
                        Bekijk Concertagenda
                    </a>
                    <a
                        href="/contact"
                        class="bg-white text-primary hover:bg-gray-50 font-bold px-8 py-4 rounded-xl transition-all border-2 border-primary shadow-md hover:shadow-lg"
                    >
                        Neem Contact Op
                    </a>
                </div>
            </div>
        </div>
    </Section>
</BaseLayout>
