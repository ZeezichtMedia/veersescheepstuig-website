{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/bestuur\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/combo\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/concerten\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/contact\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dirigent\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/fotos-videos\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/geschiedenis\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/koor\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/ledenportaal\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/onze-muziek\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/repertoire\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}